# ---------------------------------------------------------------------------
# Secrets — NEVER commit. (.env holds real API keys; .env.example is the template
# and IS committed.) `.env` with no leading path matches at any directory depth.
# ---------------------------------------------------------------------------
.env
backend/.env
frontend/.env
# Production secrets file (the .example template IS committed).
.env.prod
*.key
*.pem

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
backend/.venv/

# --- Node / frontend ---
node_modules/
dist/
frontend/dist/
*.tsbuildinfo

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# --- Local tooling (Claude Code plans/settings) ---
.claude/

# --- Misc ---
*.log

# Local-only compose overrides (e.g. pointing the API at a specific DB).
docker-compose.override.yml

# Local branding assets (logo) mounted into the container; not committed.
branding/
