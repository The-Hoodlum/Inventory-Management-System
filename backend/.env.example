# ---------------------------------------------------------------------------
# Copy to .env and adjust. Do NOT commit real secrets.
# ---------------------------------------------------------------------------

# App
APP_NAME="Inventory & Procurement API"
ENVIRONMENT=development
DEBUG=false
API_V1_PREFIX=/api/v1

# Database — MUST use the async driver (postgresql+asyncpg://).
# The app connects as a NON-superuser role so PostgreSQL RLS is enforced.
DATABASE_URL=postgresql+asyncpg://app_user:app_pw@localhost:5432/inventory
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# JWT — generate a long random secret, e.g.  openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_use_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO
LOG_JSON=true

# ---------------------------------------------------------------------------
# Freightos freight-rate intelligence (OPTIONAL external source)
#
# A Freightos developer app issues BOTH an API key and a secret. Both are
# required when enabled. Leave FREIGHTOS_ENABLED=false (or either value blank)
# and the source stays inert — no network calls, no data, platform behaves
# exactly as before. To activate, set FREIGHTOS_ENABLED=true and paste YOUR
# key + secret into the two vars below in your LOCAL .env (this example file
# must NEVER contain real secrets). If enabled in production with either value
# missing, the app refuses to start.
# ---------------------------------------------------------------------------
FREIGHTOS_ENABLED=false
FREIGHTOS_API_KEY=
FREIGHTOS_API_SECRET=
# Auth flow: basic (default) | oauth2 | headers — see
# app/intelligence/sources/freightos.py. oauth2 uses FREIGHTOS_TOKEN_URL.
FREIGHTOS_AUTH_MODE=basic
FREIGHTOS_TOKEN_URL=https://api.freightos.com/oauth/token
FREIGHTOS_BASE_URL=https://api.freightos.com/api/v1
# Freightos CO2 API endpoint (POST /co2calc) — confirm against your plan.
FREIGHTOS_INDEX_PATH=/co2calc
FREIGHTOS_TIMEOUT_SECONDS=20
# Lanes to pull (comma-separated origin-destination UN/LOCODEs); blank = defaults.
FREIGHTOS_LANES=CNSHA-USLAX,CNSHA-NLRTM

# AI Supply Chain Analyst (OPTIONAL LLM narration; Phase 10)
# The advisor always serves a deterministic, explainable briefing. Set
# ADVISOR_LLM_ENABLED=true AND paste an ANTHROPIC_API_KEY to also have Claude
# narrate the (grounded) findings. Left disabled, no external call is made.
ADVISOR_LLM_ENABLED=false
ANTHROPIC_API_KEY=
ADVISOR_MODEL=claude-opus-4-8
ADVISOR_BASE_URL=https://api.anthropic.com/v1/messages
ADVISOR_MAX_TOKENS=1024
ADVISOR_TIMEOUT_SECONDS=30

# External intelligence providers (production feeds; all OPTIONAL, inert by default)
# Enable a provider to let ingest / the daily scheduler pull from it and convert the
# result into intelligence signals (which already feed risk, forecasting, reorder).
# Free providers need no key except OpenWeather (and Comtrade's subscription key).
INTEL_HTTP_TIMEOUT_SECONDS=20
INTEL_EXCHANGERATE_ENABLED=false
INTEL_EXCHANGERATE_API_KEY=
INTEL_WORLDBANK_ENABLED=false
INTEL_IMF_ENABLED=false
INTEL_GDELT_ENABLED=false
INTEL_COMTRADE_ENABLED=false
INTEL_COMTRADE_API_KEY=
INTEL_OPENWEATHER_ENABLED=false
INTEL_OPENWEATHER_API_KEY=
# Daily background pull (per tenant) -> signals -> risk -> supplier scores. Off by default.
INTEL_SCHEDULER_ENABLED=false
INTEL_SCHEDULER_INTERVAL_HOURS=24
