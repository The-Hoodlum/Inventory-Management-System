# ============================================================================
#  Root environment example. Copy to ".env" to override docker-compose defaults:
#      cp .env.example .env            (Windows PowerShell: Copy-Item .env.example .env)
#
#  Everything here has a working default baked into docker-compose.yml, so the
#  stack runs even with NO .env file. Create one only to customise.
# ============================================================================

# --- Database (compose) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inventory
DB_PORT=5432                 # host port for Postgres (change if 5432 is taken, e.g. 5433)

# --- API (compose) ---
API_PORT=8000                # host port for the backend API
ENVIRONMENT=development       # development | staging | production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# The API connects to the db container as the non-superuser app_user (RLS enforced).
DATABASE_URL=postgresql+asyncpg://app_user:app_pw@db:5432/inventory

# JWT secret. The default below is a throwaway dev value. In production the app
# REFUSES to start with a weak/default secret — generate one:  openssl rand -hex 32
JWT_SECRET_KEY=dev-only-change-me-0123456789abcdef0123456789abcdef

# --- Freightos freight intelligence (compose; OPTIONAL) ---
# Requires BOTH an API key and a secret from the Freightos developer portal.
# Inert unless enabled with both. Paste YOUR values into your local .env only
# (this example file must NOT hold real secrets). Enabled-but-missing in
# production stops the app from starting.
FREIGHTOS_ENABLED=false
FREIGHTOS_API_KEY=
FREIGHTOS_API_SECRET=
FREIGHTOS_AUTH_MODE=basic                       # basic | oauth2 | headers
FREIGHTOS_TOKEN_URL=https://api.freightos.com/oauth/token
FREIGHTOS_BASE_URL=https://api.freightos.com/api/v1
FREIGHTOS_INDEX_PATH=/co2calc
FREIGHTOS_LANES=CNSHA-USLAX,CNSHA-NLRTM

# --- AI Supply Chain Analyst (compose; OPTIONAL LLM narration; Phase 10) ---
# Deterministic briefing always works; set ADVISOR_LLM_ENABLED=true + a key for
# live Claude narration. Inert (no external call) otherwise.
ADVISOR_LLM_ENABLED=false
ANTHROPIC_API_KEY=
ADVISOR_MODEL=claude-opus-4-8

# --- Conversational assistant (WhatsApp/OpenAI; compose; OPTIONAL, inert by default) ---
# Set ASSISTANT_ENABLED=true + an OPENAI_API_KEY to enable natural-language Q&A.
ASSISTANT_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Proactive alerts (low-stock / daily / weekly / pending-PO) over WhatsApp; off by default.
ASSISTANT_ALERTS_ENABLED=false
# WhatsApp channel: 'mock' (default) or 'cloud' (Meta WhatsApp Cloud API). For 'cloud',
# set the phone-number id, access token, verify token, and (single-tenant) default tenant.
WHATSAPP_PROVIDER=mock
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_DEFAULT_TENANT_ID=

# --- External intelligence providers + daily scheduler (compose; OPTIONAL) ---
# All inert by default. Enable providers + the scheduler to pull real macro/geo data
# daily and convert it into intelligence signals (free; OpenWeather/Comtrade keyed).
INTEL_EXCHANGERATE_ENABLED=false
INTEL_EXCHANGERATE_API_KEY=
INTEL_WORLDBANK_ENABLED=false
INTEL_IMF_ENABLED=false
INTEL_GDELT_ENABLED=false
INTEL_OPENWEATHER_ENABLED=false
INTEL_OPENWEATHER_API_KEY=
INTEL_COMTRADE_ENABLED=false
INTEL_COMTRADE_API_KEY=
INTEL_SCHEDULER_ENABLED=false
INTEL_SCHEDULER_INTERVAL_HOURS=24

# --- Frontend (used by `npm run dev` in ./frontend; not read by compose) ---
# Put this in frontend/.env (it's already there via frontend/.env.example).
VITE_API_BASE_URL=http://localhost:8000/api/v1
