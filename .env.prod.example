# ============================================================================
#  Production environment for docker-compose.prod.yml.
#  Copy to .env.prod and fill in. NEVER commit the filled file.
#    cp .env.prod.example .env.prod
#  Generate strong secrets:
#    JWT_SECRET_KEY   ->  openssl rand -hex 32
#    POSTGRES_PASSWORD -> openssl rand -base64 24
# ============================================================================

# --- Database (the port is NOT published; these stay on the internal network) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=inventory

# --- First-boot administrator (created once, on the first empty-DB boot) ---
# Change ADMIN_PASSWORD after your first login.
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
TENANT_NAME=My Company
TENANT_SLUG=main

# --- API ---
# 32+ char random string. Rotating it invalidates all existing sessions.
JWT_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
# The public URL the browser loads the app from (scheme + host, no trailing slash).
CORS_ORIGINS=https://erp.yourcompany.com
# The API connects to the DB as the internal, non-superuser app_user (RLS-enforced).
# Rotate app_pw for real production (see docs/DEPLOYMENT.md, "Harden the DB role").
DATABASE_URL=postgresql+asyncpg://app_user:app_pw@db:5432/inventory

# --- Web tier ---
# Host port nginx listens on. Keep 80 if a TLS reverse proxy (Caddy/Cloudflare) is in
# front; otherwise set to 443 only after wiring certificates.
WEB_PORT=80

# --- Optional integrations (all OFF by default; enable + add a key to turn on) ---
ADVISOR_LLM_ENABLED=false
ANTHROPIC_API_KEY=
ADVISOR_MODEL=claude-opus-4-8

ASSISTANT_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- WhatsApp channel (staff assistant over WhatsApp + opt-in alert push) ---
# Full step-by-step: docs/WHATSAPP.md
# Leave PROVIDER=mock to keep it inert (messages are recorded, never sent).
# Set PROVIDER=cloud only once you have a Meta phone-number id + access token.
WHATSAPP_PROVIDER=mock
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
# Any random string you invent; you paste the SAME value into Meta's webhook setup.
#   openssl rand -hex 16
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v23.0
# The tenant inbound messages belong to. WITHOUT this, webhooks are acknowledged but
# never answered. Get it after first boot:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod exec db \
#     psql -U postgres -d inventory -tAc "SELECT id FROM tenants LIMIT 1;"
WHATSAPP_DEFAULT_TENANT_ID=

FREIGHTOS_ENABLED=false
FREIGHTOS_API_KEY=
FREIGHTOS_API_SECRET=

INTEL_SCHEDULER_ENABLED=false
